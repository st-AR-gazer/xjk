(secure_headers) {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

(favicon_redirect) {
	@favicon path /favicon.ico
	redir @favicon /favicon.svg 308
}

(shared_static) {
	handle /shared/* {
		root * {$XJK_SITES_ROOT:D:/srv/xjk/sites}
		file_server
	}
}

(shared_core_static) {
	handle /shared/xjk-core/* {
		root * {$XJK_SITES_ROOT:D:/srv/xjk/sites}
		file_server
	}
	handle /shared/xjk-workspace/* {
		root * {$XJK_SITES_ROOT:D:/srv/xjk/sites}
		file_server
	}
}

{args[0]}xjk.yt, {args[0]}www.xjk.yt {
	import secure_headers
	import favicon_redirect
	import shared_static
	handle /xjk-account-widget.js {
		root * {$XJK_SITES_ROOT:D:/srv/xjk/sites}/shared/xjk-core
		file_server
	}
	handle /auth/* {
		reverse_proxy 127.0.0.1:3038
	}
	handle /api/v1/account/* {
		reverse_proxy 127.0.0.1:3038
	}
	handle /account* {
		reverse_proxy 127.0.0.1:3038
	}
	handle /admin {
		redir https://admin.xjk.yt/ 308
	}
	handle /admin/* {
		redir https://admin.xjk.yt/ 308
	}
	root * {$XJK_SITES_ROOT:D:/srv/xjk/sites}/xjk.yt/frontend
	file_server
}

{args[0]}account.xjk.yt {
	import secure_headers
	import favicon_redirect
	import shared_static
	reverse_proxy 127.0.0.1:3038
}

{args[0]}learn.xjk.yt {
