	}
	handle /bingo/auth/* {
		reverse_proxy 127.0.0.1:3037
	}
	handle /bingo/events/* {
		reverse_proxy 127.0.0.1:3037
	}
	handle {
		root * {$XJK_SITES_ROOT:D:/srv/xjk/sites}/console.xjk.yt/frontend
		file_server
	}
}

