	redir @rmtExact /rmt/ 308
	@comingSoonExact path /coming-soon
	redir @comingSoonExact /coming-soon/ 308
	handle /auth/* {
		reverse_proxy 127.0.0.1:3038
	}
	handle /api/v1/account/* {
