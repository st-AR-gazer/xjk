	import secure_headers
	redir https://trackers.xjk.yt/club{uri} 308
}

{args[0]}trackers.xjk.yt {
	import secure_headers
	import favicon_redirect
	import shared_core_static
	handle /auth/* {
		reverse_proxy 127.0.0.1:3038
	}
	handle /api/v1/account/* {
		reverse_proxy 127.0.0.1:3038
	}
	root * {$XJK_SITES_ROOT:D:/srv/xjk/sites}/trackers.xjk.yt/frontend

	@wrRuntimeExact path /__runtime/wr
	redir @wrRuntimeExact /__runtime/wr/ 308
	handle_path /__runtime/wr/* {
		reverse_proxy 127.0.0.1:3031
	}

	@leaderboardRuntimeExact path /__runtime/leaderboard
	redir @leaderboardRuntimeExact /__runtime/leaderboard/ 308
	handle_path /__runtime/leaderboard/* {
		reverse_proxy 127.0.0.1:3043
	}

	@displaynameRuntimeExact path /__runtime/displayname
	redir @displaynameRuntimeExact /__runtime/displayname/ 308
	handle_path /__runtime/displayname/* {
		reverse_proxy 127.0.0.1:3041
	}

	@clubRuntimeExact path /__runtime/club
	redir @clubRuntimeExact /__runtime/club/ 308
	handle_path /__runtime/club/* {
		reverse_proxy 127.0.0.1:3042
	}

	@wrExact path /wr
	redir @wrExact /wr/ 308
	@wrIndex path /wr/index.html
	redir @wrIndex /wr/ 308
	@wrShell path /wr/
	handle @wrShell {
		rewrite * /index.html
		file_server
	}
	handle_path /wr/* {
		reverse_proxy 127.0.0.1:3031
	}

	@leaderboardExact path /leaderboard
	redir @leaderboardExact /leaderboard/ 308
	@leaderboardIndex path /leaderboard/index.html
	redir @leaderboardIndex /leaderboard/ 308
	@leaderboardShell path /leaderboard/
	handle @leaderboardShell {
		rewrite * /index.html
		file_server
	}
	handle_path /leaderboard/* {
		reverse_proxy 127.0.0.1:3043
	}

	@displaynameExact path /displayname
	redir @displaynameExact /displayname/ 308
	@displaynameIndex path /displayname/index.html
	redir @displaynameIndex /displayname/ 308
	@displaynameShell path /displayname/
	handle @displaynameShell {
		rewrite * /index.html
		file_server
	}
	handle_path /displayname/* {
		reverse_proxy 127.0.0.1:3041
	}

	@clubExact path /club
	redir @clubExact /club/ 308
	@clubIndex path /club/index.html
	redir @clubIndex /club/ 308
	@clubShell path /club/
	handle @clubShell {
		rewrite * /index.html
		file_server
	}
	handle_path /club/* {
		reverse_proxy 127.0.0.1:3042
	}

	handle /admin* {
		reverse_proxy 127.0.0.1:3031
	}

	handle /api/v1* {
		reverse_proxy 127.0.0.1:3031
	}

	file_server
}

