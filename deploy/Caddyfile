{
  email admin@xjk.yt
}

(secure_headers) {
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
  }
}

xjk.yt, www.xjk.yt {
  import secure_headers
  root * C:/srv/xjk/sites/xjk.yt/frontend
  file_server
}

learn.xjk.yt {
  import secure_headers
  root * C:/srv/xjk/sites/learn.xjk.yt/frontend
  file_server
}

