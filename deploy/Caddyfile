(secure_headers) {
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
  }
}

xjk.yt, www.xjk.yt {
  import secure_headers
  root * C:/srv/xjk/sites/xjk.yt/frontend
  file_server
}

learn.xjk.yt {
  import secure_headers
  root * C:/srv/xjk/sites/learn.xjk.yt/frontend
  file_server
}

altered.xjk.yt {
  import secure_headers
  reverse_proxy 127.0.0.1:3030
}

alterednadeo.xjk.yt {
  import secure_headers
  redir https://altered.xjk.yt{uri} 308
}

tracker.xjk.yt {
  import secure_headers
  redir https://trackers.xjk.yt/wr{uri} 308
}

aggregator.xjk.yt {
  import secure_headers
  reverse_proxy 127.0.0.1:3040
}

tracker-displayname.xjk.yt {
