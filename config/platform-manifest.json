      "cwd": "sites/tools.xjk.yt/Embed-RaceValidationGhost/backend",
      "entry": "server.js",
      "runtime": "node",
      "ports": {
        "production": 3012,
        "local": 3112,
        "localParameter": "EmbedPort",
        "localEnvironmentVariable": "TOOLS_EMBED_PORT"
      },
      "health": { "path": "/health", "required": true }
