    },
    {
      "id": "tracker-hub",
      "processName": "xjk-tracker-hub",
      "localName": "tracker-hub",
      "cwd": "services/tracker",
      "entry": "server.js",
      "runtime": "node",
      "ports": {
        "production": 3031,
        "local": 3131,
        "localParameter": "TrackerHubPort",
        "localEnvironmentVariable": "TRACKER_HUB_PORT"
      },
      "health": { "path": "/api/v1/tracker/status", "required": true }
    },
    {
      "id": "tracker-leaderboard-hub",
      "processName": "xjk-tracker-leaderboard-hub",
