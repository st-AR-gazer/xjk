      "id": "tools-medal-modifier",
      "processName": "xjk-tools-medal-modifier",
      "localName": "tools-medal-modifier",
      "cwd": "sites/tools.xjk.yt/Gbx-Medal-Time-Modifier/backend",
      "entry": "server.js",
      "runtime": "node",
