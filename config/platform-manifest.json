      "id": "tools-extract-replay",
      "processName": "xjk-tools-extract-replay",
      "localName": "tools-extract-replay",
      "cwd": "sites/tools.xjk.yt/Extract-Replay-Data/backend",
      "entry": "server.js",
      "runtime": "node",
      "ports": {
        "production": 3014,
        "local": 3114,
        "localParameter": "ExtractReplayPort",
        "localEnvironmentVariable": "TOOLS_EXTRACT_REPLAY_PORT"
      },
      "health": { "path": "/health", "required": true }
    },
