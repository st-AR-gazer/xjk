      "id": "validifier-public",
      "processName": "xjk-validifier-public",
      "localName": "validifier-public",
      "cwd": "services/validifier-public",
      "entry": "server.js",
      "runtime": "node",
      "ports": {
        "production": 3044,
        "local": 3144,
        "localParameter": "ValidifierPublicPort",
        "localEnvironmentVariable": "VALIDIFIER_PUBLIC_PORT"
      },
      "health": { "path": "/health", "required": true }
    },
    {
      "id": "cotd-public",
      "processName": "xjk-cotd-public",
      "localName": "cotd-public",
      "cwd": "services/cotd-public",
      "entry": "server.js",
      "runtime": "node",
      "ports": {
        "production": 3045,
        "local": 3145,
        "localParameter": "CotdPublicPort",
        "localEnvironmentVariable": "COTD_PUBLIC_PORT"
