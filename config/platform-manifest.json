  "tools": [
    {
      "id": "map-cleaner",
      "path": "Strip-RaceValidationGhost",
      "serviceId": "tools-strip",
      "executableName": "stripValidationReplay.exe",
      "runtimeFileId": "strip-race-validation-ghost",
      "listed": true,
      "name": "Strip Race Validation Ghost",
      "description": "Upload a map, strip the validation replay, and optionally export cleaned map and extracted ghost files. Clone-enabled maps are accepted, and clone state is always cleared in returned maps.",
      "category": "Validation",
      "status": "live",
      "input": ".Map.Gbx",
      "output": "Map / Ghost / Zip",
      "tone": "cool"
    },
    {
      "id": "ghost-embedder",
      "path": "Embed-RaceValidationGhost",
      "serviceId": "tools-embed",
      "executableName": "EmbedRaceValidationGhost.exe",
      "runtimeFileId": "embed-race-validation-ghost",
      "listed": true,
      "name": "Embed Race Validation Ghost",
      "description": "Upload a map and a ghost/replay source, pick replay ghost index if needed, then download embedded map output.",
      "category": "Validation",
      "status": "live",
      "input": ".Map.Gbx + .Ghost/.Replay.Gbx",
      "output": "Embedded .Map.Gbx",
      "tone": "warm"
    },
    {
      "id": "embedded-checker",
      "path": "Embedded-Blocks-And-Items-Checker",
      "serviceId": "tools-embedded-checker",
      "executableName": "EmbeddedBlocksAndItemsChecker.exe",
      "runtimeFileId": "embedded-blocks-and-items-checker",
      "listed": true,
      "name": "Embedded Blocks And Items Checker",
      "description": "Check map embedding consistency and inspect missing expected/custom embedded models.",
      "category": "Inspection",
      "status": "live",
      "input": ".Map.Gbx",
      "output": "JSON report",
      "tone": "cool"
    },
    {
      "id": "replay-data-extractor",
      "path": "Extract-Replay-Data",
      "serviceId": "tools-extract-replay",
      "executableName": "ReplayDataExtractor.exe",
      "runtimeFileId": "replay-data-extractor",
      "listed": true,
      "name": "Extract Replay Data",
      "description": "Extract structured replay JSON using default projection or a custom request selection.",
      "category": "Replay",
      "status": "live",
      "input": ".Replay.Gbx",
      "output": "JSON data",
      "tone": "cool"
    },
    {
      "id": "medal-time-modifier",
      "path": "Gbx-Medal-Time-Modifier",
      "serviceId": "tools-medal-modifier",
      "executableName": "GbxMedalTimeModifier.exe",
      "runtimeFileId": "gbx-medal-time-modifier",
      "listed": true,
      "name": "GBX Medal Time Modifier",
      "description": "Set AT/Gold/Silver/Bronze medal values for a map and download the modified map file.",
      "category": "Map Editing",
      "status": "live",
      "input": ".Map.Gbx + medal values",
      "output": "Modified .Map.Gbx",
      "tone": "warm"
    },
    {
      "id": "map-validation-checker",
      "path": "Map-Validation-Checker",
      "serviceId": "tools-map-validation",
      "executableName": "MapValidationChecker.exe",
      "runtimeFileId": "map-validation-checker",
      "listed": true,
      "name": "Map Validation Checker",
      "description": "Inspect map validation status with optional replay evidence and manual override support.",
      "category": "Validation",
      "status": "live",
      "input": ".Map.Gbx (+ optional replay/manual)",
      "output": "JSON verdict",
      "tone": "cool"
    },
    {
      "id": "underwater-converter",
      "path": "Underwater-Map-Converter",
      "serviceId": "tools-underwater",
      "executableName": "UnderwaterMapConverter.exe",
      "runtimeFileId": "underwater-map-converter",
      "listed": true,
      "name": "Underwater Map Converter",
      "description": "Convert any Trackmania 2020 map into an underwater variant with automatic environment detection and water carrier placement.",
      "category": "Map Conversion",
      "status": "live",
      "input": ".Map.Gbx",
      "output": "Underwater .Map.Gbx / Zip",
      "tone": "cool"
    },
    {
      "id": "colorizer",
      "path": "Colorizer",
      "serviceId": null,
      "executableName": null,
      "runtimeFileId": null,
      "listed": true,
      "name": "TM Gradient Color Formatter",
      "description": "Format Trackmania text with per-letter gradient color codes (supports custom palettes & presets).",
      "category": "Text",
      "status": "live",
      "input": "Text + 2-7 colors",
      "output": "Formatted gradient string",
      "tone": "warm"
    },
    {
      "id": "clip-to-ghost",
      "path": "Clip-To-Ghost",
      "serviceId": "tools-clip-to-ghost",
      "executableName": "ClipToGhost.exe",
      "runtimeFileId": "clip-to-ghost",
      "listed": true,
      "name": "Clip To Ghost",
      "description": "Export GPS clip RecordData blocks from Trackmania maps into standalone ghost files with optional manifest output.",
      "category": "Ghost Export",
      "status": "live",
      "input": ".Map.Gbx",
      "output": ".Ghost.Gbx + manifest",
      "tone": "cool"
    },
    {
      "id": "replay-verification",
      "path": "Replay-Verification",
      "serviceId": "tools-replay-verification",
      "executableName": null,
      "runtimeFileId": null,
      "listed": false,
      "name": "Replay Verification",
      "description": "Verify replay evidence against a Trackmania map.",
      "category": "Validation",
      "status": "internal",
      "input": ".Map.Gbx + .Replay.Gbx",
      "output": "Verification report",
      "tone": "cool"
    }
  ]
}
