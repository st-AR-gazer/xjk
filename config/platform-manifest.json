      "localName": "altered-bannerbuilder",
      "cwd": "services/bannerbuilder",
      "entry": "app.py",
      "runtime": "python",
      "ports": {
        "production": 3050,
        "local": 3135,
        "localParameter": "AlteredBannerBuilderPort",
        "localEnvironmentVariable": "ALTERED_BANNER_BUILDER_PORT"
      },
