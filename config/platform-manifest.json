      "processName": "xjk-tools-embedded-checker",
      "localName": "tools-embedded-checker",
      "cwd": "sites/tools.xjk.yt/Embedded-Blocks-And-Items-Checker/backend",
      "entry": "server.js",
      "runtime": "node",
      "ports": {
        "production": 3013,
