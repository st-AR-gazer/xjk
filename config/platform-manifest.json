      "host": "altered.xjk.yt",
      "aliases": ["alterednadeo.xjk.yt"],
      "frontend": "sites/altered.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "trackers",
      "name": "Trackers",
      "host": "trackers.xjk.yt",
      "aliases": ["tracker.xjk.yt", "tracker-displayname.xjk.yt", "tracker-club.xjk.yt"],
      "frontend": "sites/trackers.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "aggregator",
      "name": "Aggregator",
      "host": "aggregator.xjk.yt",
      "aliases": [],
      "frontend": "sites/aggregator.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "validifier",
      "name": "Validifier",
      "host": "validifier.xjk.yt",
      "aliases": [],
      "frontend": "sites/validifier.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "cotd",
      "name": "COTD",
      "host": "cotd.xjk.yt",
      "aliases": [],
      "frontend": "sites/cotd.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "dash",
      "name": "Dashboard",
      "host": "dash.xjk.yt",
      "aliases": [],
      "frontend": "sites/dash.xjk.yt/frontend",
      "visibility": "private"
    },
    {
      "id": "admin",
      "name": "Admin",
      "host": "admin.xjk.yt",
      "aliases": [],
      "frontend": "sites/admin.xjk.yt/frontend",
      "visibility": "private"
    },
    {
      "id": "plugins",
      "name": "Plugins",
      "host": "plugins.xjk.yt",
      "aliases": [],
      "frontend": "sites/plugins.xjk.yt/Plugins-Hub/frontend",
      "visibility": "public"
    },
    {
      "id": "tools",
      "name": "Tools",
      "host": "tools.xjk.yt",
      "aliases": [],
      "frontend": "sites/tools.xjk.yt/Tools-Hub/frontend",
      "visibility": "public"
    }
  ],
  "services": [
