{
  "$schema": "./platform-manifest.schema.json",
  "schemaVersion": 1,
  "assetVersion": "2",
  "infrastructure": {
    "localGateway": {
      "port": 8080,
      "portParameter": "GatewayPort",
      "rootSiteId": "xjk"
    },
    "localhostBrowserProxy": {
      "port": 8877,
      "managedByStackReset": false
    },
    "security": {
      "localOnlyOverrides": [
        {
          "serviceId": "aggregator-hub",
          "environmentVariable": "AGGREGATOR_ALLOW_INSECURE_OPEN",
          "localValue": "1",
          "allowedInProduction": false
        },
        {
          "serviceId": "bannerbuilder",
          "environmentVariable": "BANNERBUILDER_ALLOW_EPHEMERAL_SECRET",
          "localValue": "1",
          "allowedInProduction": false
        },
        {
          "serviceId": "bannerbuilder",
          "environmentVariable": "BANNERBUILDER_COOKIE_SECURE",
          "localValue": "0",
          "allowedInProduction": false
        }
      ]
    }
  },
  "routing": {
    "tools": {
      "siteId": "tools",
      "rootServiceId": "tools-hub"
    },
    "tracker": {
      "siteId": "trackers",
      "rootServiceId": "tracker-hub",
      "modes": [
        { "path": "wr", "serviceId": "tracker-hub" },
        { "path": "leaderboard", "serviceId": "tracker-leaderboard-hub" },
        { "path": "displayname", "serviceId": "tracker-displayname-hub" },
        { "path": "club", "serviceId": "tracker-club-hub" }
      ]
    }
  },
  "sites": [
    {
      "id": "xjk",
      "name": "Main",
      "host": "xjk.yt",
      "aliases": ["www.xjk.yt"],
      "frontend": "sites/xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "account",
      "name": "Account",
      "host": "account.xjk.yt",
      "aliases": [],
      "frontend": "sites/account.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "learn",
      "name": "Learn",
      "host": "learn.xjk.yt",
      "aliases": [],
      "frontend": "sites/learn.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "console",
      "name": "Console",
      "host": "console.xjk.yt",
      "aliases": ["bingo.xjk.yt"],
      "frontend": "sites/console.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "archive",
      "name": "Archive",
      "host": "archive.xjk.yt",
      "aliases": [],
      "frontend": "sites/archive.xjk.yt/frontend",
      "visibility": "public"
    },
    {
      "id": "altered",
