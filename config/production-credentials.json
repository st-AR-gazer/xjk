{
  "schemaVersion": 1,
  "services": {
    "xjk-auth": {
      "required": [],
      "optional": ["XJK_ADMIN_UBISOFT_ACCOUNT_IDS", "XJK_ADMIN_UBISOFT_SUBJECTS"],
      "conditional": [
        {
          "feature": "shared Ubisoft OAuth",
          "when": { "key": "UBI_OAUTH_ENABLED", "operator": "truthy" },
          "allOf": ["UBI_OAUTH_CLIENT_ID", "UBI_OAUTH_CLIENT_SECRET"]
        }
      ]
    },
    "learn-profile": {
      "required": [],
      "optional": [
        "LEARN_HEAD_ADMIN_SUBJECTS",
        "LEARN_HEAD_ADMIN_USERNAMES",
        "LEARN_EDITOR_SUBJECTS",
        "LEARN_EDITOR_USERNAMES"
      ],
      "conditional": [
        {
          "feature": "Learn Ubisoft OAuth",
          "when": { "key": "LEARN_UBI_OAUTH_ENABLED", "operator": "truthy" },
          "allOf": ["LEARN_UBI_OAUTH_CLIENT_ID", "LEARN_UBI_OAUTH_CLIENT_SECRET"]
        }
      ]
    },
    "console-hub": {
      "required": ["CONSOLE_HUB_BINGO_AUTH_SECRET"],
      "optional": [
        "CONSOLE_HUB_OPERATOR_ACCESS_TOKEN",
        "CONSOLE_HUB_OPERATOR_REFRESH_TOKEN",
        "TM_SERVICE_ACCOUNT_LOGIN",
        "TM_SERVICE_ACCOUNT_PASSWORD"
      ],
      "conditional": [
        {
          "feature": "Console Ubisoft OAuth",
          "when": { "key": "CONSOLE_HUB_UBI_OAUTH_ENABLED", "operator": "truthy" },
          "allOf": ["CONSOLE_HUB_UBI_OAUTH_CLIENT_ID", "CONSOLE_HUB_UBI_OAUTH_CLIENT_SECRET"]
        }
      ]
    },
    "validifier-public": {
      "required": [],
      "optional": ["VALIDIFIER_INTERNAL_TOKEN", "VALIDIFIER_INTERNAL_ACCESS_TOKEN", "VALIDIFIER_REPLAY_BUILD_ID"],
      "conditional": [
        {
          "feature": "private Validifier submission backend",
          "when": { "key": "VALIDIFIER_INTERNAL_BASE_URL", "operator": "present" },
          "allOf": ["VALIDIFIER_INTERNAL_SUBMISSION_SECRET"]
        }
      ]
    },
    "cotd-public": {
      "required": ["COTD_ADMIN_TOKEN"],
      "optional": [
        "COTD_TOTD_SOURCE_TOKEN",
        "COTD_CLASSIFIER_TOKEN",
        "COTD_NADEO_SERVICES_TOKEN",
        "COTD_NADEO_LIVE_SERVICES_TOKEN",
        "COTD_NADEO_DEDI_LOGIN",
        "COTD_NADEO_DEDI_PASSWORD"
      ],
      "conditional": [
        {
          "feature": "scheduled COTD fetch",
          "when": { "key": "COTD_TOTD_FETCH_ENABLED", "operator": "truthy" },
          "anyOfGroups": [
            ["COTD_TOTD_SOURCE_URL"],
            ["COTD_NADEO_DEDI_LOGIN", "COTD_NADEO_DEDI_PASSWORD"],
            ["COTD_NADEO_SERVICES_TOKEN", "COTD_NADEO_LIVE_SERVICES_TOKEN"]
          ]
        }
      ]
    },
    "altered-hub": {
      "required": ["ALTERED_INTERNAL_TOKEN", "ALTERED_WR_WEBHOOK_SECRET"],
      "optional": ["ALTERED_ADMIN_TOKEN", "TRACKER_ADMIN_TOKEN"],
      "conditional": [
        {
          "feature": "Altered Ubisoft OAuth",
          "when": { "key": "UBI_OAUTH_ENABLED", "operator": "truthy" },
          "allOf": ["UBI_OAUTH_CLIENT_ID", "UBI_OAUTH_CLIENT_SECRET"]
        },
        {
          "feature": "Altered live monitoring",
          "when": { "key": "ALTERED_LIVE_MONITOR_ENABLED", "operator": "truthy" },
          "anyOfGroups": [
            ["ALTERED_LIVE_DEDI_LOGIN", "ALTERED_LIVE_DEDI_PASSWORD"],
            ["TRACKER_NADEO_DEDI_LOGIN", "TRACKER_NADEO_DEDI_PASSWORD"],
            ["ALTERED_LIVE_ACCESS_TOKEN"],
            ["ALTERED_LIVE_REFRESH_TOKEN"],
            ["TRACKER_NADEO_LIVE_ACCESS_TOKEN"],
            ["TRACKER_NADEO_LIVE_REFRESH_TOKEN"]
          ]
        }
      ]
    },
    "bannerbuilder": {
      "required": ["SECRET_KEY", "ADMIN_PWHASH"],
      "optional": ["ADMIN_PASSWORD", "DASHMAP_API_KEY", "DASHMAP_USER"],
      "conditional": []
    },
    "tracker-hub": {
      "required": ["TRACKER_ADMIN_TOKEN"],
      "optional": ["TRACKER_NADEO_LIVE_ACCESS_TOKEN", "TRACKER_NADEO_LIVE_REFRESH_TOKEN"],
      "conditional": [
        {
          "feature": "Nadeo live tracker provider",
          "when": { "key": "TRACKER_PROVIDER", "operator": "equals", "value": "nadeo-live" },
          "anyOfGroups": [
            ["TRACKER_NADEO_DEDI_LOGIN", "TRACKER_NADEO_DEDI_PASSWORD"],
            ["TRACKER_NADEO_LIVE_ACCESS_TOKEN"]
          ]
        },
        {
          "feature": "WR webhook reporting",
          "when": { "key": "TRACKER_WR_WEBHOOK_ENABLED", "operator": "truthy" },
          "allOf": ["TRACKER_WR_WEBHOOK_SECRET"]
        },
        {
          "feature": "tracker aggregator reporting",
          "when": { "key": "TRACKER_AGGREGATOR_ENABLED", "operator": "truthy" },
          "allOf": ["TRACKER_AGGREGATOR_TOKEN"]
        }
      ]
    },
    "tracker-leaderboard-hub": {
      "required": ["TRACKER_ADMIN_TOKEN"],
      "optional": ["TRACKER_NADEO_LIVE_ACCESS_TOKEN", "TRACKER_NADEO_LIVE_REFRESH_TOKEN"],
      "conditional": [
        {
          "feature": "Nadeo live leaderboard provider",
          "when": { "key": "TRACKER_PROVIDER", "operator": "equals", "value": "nadeo-live" },
          "anyOfGroups": [
            ["TRACKER_NADEO_DEDI_LOGIN", "TRACKER_NADEO_DEDI_PASSWORD"],
            ["TRACKER_NADEO_LIVE_ACCESS_TOKEN"]
          ]
        },
        {
          "feature": "leaderboard aggregator reporting",
          "when": { "key": "TRACKER_AGGREGATOR_ENABLED", "operator": "truthy" },
          "allOf": ["TRACKER_AGGREGATOR_TOKEN"]
        }
      ]
    },
    "aggregator-hub": {
      "required": [
        "AGGREGATOR_INGEST_TOKEN",
        "DASH_ADMIN_TOKEN",
        "DASH_ALTERED_INTERNAL_TOKEN",
        "DASH_TRACKER_ADMIN_TOKEN"
      ],
      "optional": ["ARL_OPENPLANET_AUTH_SECRET"],
      "conditional": []
    },
    "tracker-displayname-hub": {
      "required": [],
      "optional": [],
      "conditional": [
        {
          "feature": "display-name tracking",
          "when": { "key": "TRACKER_DISPLAYNAME_ENABLED", "operator": "truthy" },
          "allOf": ["UBI_OAUTH_CLIENT_ID", "UBI_OAUTH_CLIENT_SECRET", "TRACKER_DISPLAYNAME_AGGREGATOR_TOKEN"]
        }
      ]
    },
    "tracker-club-hub": {
      "required": [],
      "optional": [],
      "conditional": [
        {
          "feature": "club tracking",
          "when": { "key": "TRACKER_CLUB_ENABLED", "operator": "truthy" },
          "allOf": ["TRACKER_CLUB_AGGREGATOR_TOKEN"]
        }
      ]
    },
    "plugins-hub": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-hub": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-strip": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-embed": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-embedded-checker": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-extract-replay": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-medal-modifier": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-map-validation": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-underwater": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-clip-to-ghost": {
      "required": [],
      "optional": [],
      "conditional": []
    },
    "tools-replay-verification": {
      "required": [],
      "optional": [],
      "conditional": []
    }
  }
}
