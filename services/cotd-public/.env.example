# COTD public service
PORT=3045
FRONTEND_DIR=../../sites/cotd.xjk.yt/frontend
COTD_PUBLIC_DATA_DIR=../../sites/cotd.xjk.yt/data
COTD_PUBLIC_STORAGE_FILE=../../sites/cotd.xjk.yt/data/cotd-public.json
COTD_PUBLIC_DB_FILE=../../sites/cotd.xjk.yt/data/cotd-public.sqlite
COTD_MAP_FILES_DIR=../../sites/cotd.xjk.yt/data/maps
COTD_PUBLIC_CACHE_TTL_MS=15000
COTD_PUBLIC_CACHE_MAX_ENTRIES=256
COTD_PUBLIC_PAGINATION_MAX_OFFSET=10000
COTD_HISTORY_LIMIT=2500

# Optional for local read-only use; required by production preflight.
# If unset, /api/v1/admin/ingest returns admin_not_configured.
COTD_ADMIN_TOKEN=

# Optional Track of the Day fetch source. Polling stays disabled until a real JSON source is configured.
COTD_TOTD_FETCH_ENABLED=0
COTD_TOTD_FETCH_ON_START=1
COTD_TOTD_FETCH_INTERVAL_MS=300000
COTD_TOTD_SOURCE_URL=
COTD_TOTD_SOURCE_TOKEN=
COTD_TOTD_SOURCE_TOKEN_HEADER=Authorization
COTD_TOTD_SOURCE_TOKEN_PREFIX=Bearer
COTD_TOTD_SOURCE_TIMEOUT_MS=15000
COTD_AUTO_CLASSIFY_ENABLED=1
COTD_TOTD_SYNC_MONTH_LENGTH=1
COTD_TOTD_SYNC_MONTH_OFFSET=0
COTD_TOTD_SYNC_ROYAL=0
COTD_TOTD_DOWNLOAD_MAP_FILES=1

# Optional official Nadeo sync/download credentials.
# The monthly TOTD endpoint needs NadeoLiveServices; map info and GBX files need NadeoServices.
COTD_NADEO_AUTH_MODE=basic
COTD_NADEO_USER_AGENT=cotd.xjk.yt/1.0 (+https://xjk.yt/)
COTD_NADEO_DEDI_LOGIN=
COTD_NADEO_DEDI_PASSWORD=
COTD_NADEO_SERVICES_TOKEN=
COTD_NADEO_LIVE_SERVICES_TOKEN=
COTD_NADEO_TOKEN_CACHE_FILE=../../sites/cotd.xjk.yt/data/nadeo-token-cache.json
COTD_NADEO_REQUEST_TIMEOUT_MS=15000
COTD_NADEO_MIN_REQUEST_GAP_MS=1000
COTD_NADEO_GLOBAL_THROTTLE_FILE=
COTD_NADEO_GLOBAL_MIN_REQUEST_GAP_MS=0

# Optional generalized Trackmania Map Classifier adapter.
COTD_CLASSIFIER_BASE_URL=
COTD_CLASSIFIER_PATH=/api/v1/classify
COTD_CLASSIFIER_TOKEN=
COTD_CLASSIFIER_TOKEN_HEADER=Authorization
COTD_CLASSIFIER_TOKEN_PREFIX=Bearer
COTD_CLASSIFIER_TIMEOUT_MS=15000

# Raw/debug payloads also require COTD_ADMIN_TOKEN and the matching request token.
COTD_ALLOW_DEBUG_RAW=0
