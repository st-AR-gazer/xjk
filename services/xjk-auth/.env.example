# Shared xjk auth/account service
PORT=3038
XJK_PUBLIC_ORIGIN=https://xjk.yt
XJK_LOCAL_PUBLIC_ORIGIN=http://localhost:8080
XJK_AUTH_DB_FILE=../../sites/xjk.yt/data/xjk-auth.sqlite
XJK_AUTH_SESSION_COOKIE_NAME=xjk_session
XJK_AUTH_SESSION_COOKIE_DOMAIN=.xjk.yt
XJK_AUTH_SESSION_TTL_SECONDS=2592000
XJK_AUTH_OAUTH_STATE_TTL_SECONDS=600
XJK_AUTH_OAUTH_STATE_MAX_ENTRIES=1024
XJK_AUTH_OAUTH_NONCE_COOKIE_NAME=xjk_oauth_nonce
XJK_AUTH_OAUTH_LOGIN_RATE_LIMIT_MAX=20
XJK_AUTH_OAUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
XJK_AUTH_USER_AGENT=xjk.yt shared auth
XJK_AUTH_REQUEST_TIMEOUT_MS=15000
# Canonical platform hosts come from sites/shared/xjk-core/site-registry.js.
# Add deployment-specific return hosts here only when needed.
XJK_AUTH_ALLOWED_RETURN_HOSTS=
XJK_ADMIN_UBISOFT_ACCOUNT_IDS=
XJK_ADMIN_UBISOFT_SUBJECTS=

# Shared Ubisoft OAuth app. Client id and secret are required when enabled.
UBI_OAUTH_ENABLED=1
UBI_OAUTH_CLIENT_ID=
UBI_OAUTH_CLIENT_SECRET=
UBI_OAUTH_AUTHORIZE_URL=https://api.trackmania.com/oauth/authorize
UBI_OAUTH_TOKEN_URL=https://api.trackmania.com/api/access_token
UBI_OAUTH_USERINFO_URL=https://api.trackmania.com/api/user
UBI_OAUTH_SCOPE=clubs
UBI_OAUTH_CALLBACK_PATH=/auth/ubisoft/callback
