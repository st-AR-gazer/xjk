# Copy to .env for local or server runtime configuration.
# The live deploy archive excludes .env on purpose, so set these on the server too.

DASHMAP_API_KEY=
DASHMAP_USER=
SECRET_KEY=
ADMIN_PWHASH=
# Legacy local fallback only; production requires ADMIN_PWHASH.
ADMIN_PASSWORD=
BANNERBUILDER_ALLOW_EPHEMERAL_SECRET=0
BANNERBUILDER_COOKIE_SECURE=1
BANNERBUILDER_MAX_PERSISTED=2000
BANNERBUILDER_MAX_PERSISTED_BYTES=536870912
BANNERBUILDER_MAX_PENDING=256
BANNERBUILDER_MAX_PENDING_BYTES=67108864
BANNERBUILDER_RATE_LIMIT=120 per minute
BANNERBUILDER_GENERATION_RATE_LIMIT=30 per minute
BANNERBUILDER_PERSIST_RATE_LIMIT=10 per minute
BANNERBUILDER_RATE_LIMIT_STORAGE_URI=memory://
